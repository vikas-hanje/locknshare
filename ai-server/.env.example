# AI Server Environment Configuration
# Optional: Set these in your environment or create .env file

# API Key Authentication (Optional - leave empty to disable)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AI_SERVER_API_KEY=

# Allowed CORS Origins (comma-separated)
# Add your Vercel deployment URL here
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Example for production with ngrok:
# ALLOWED_ORIGINS=http://localhost:3000,https://your-ngrok-subdomain.ngrok-free.app,https://your-app.vercel.app
